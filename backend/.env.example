# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=endcosmos_auth
DB_USER=endcosmos_user
DB_PASSWORD=change_this_password

# API
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# CORS (comma separated)
ALLOWED_ORIGINS=http://127.0.0.1:5500,http://localhost:5500,http://127.0.0.1:8000

# Security
SECRET_KEY=replace_with_a_long_random_secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
