# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=endcosmos_auth
DB_USER=endcosmos_user
DB_PASSWORD=change_this_password

# API
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# CORS (comma separated)
ALLOWED_ORIGINS=https://endcosmos.com,https://www.endcosmos.com,http://127.0.0.1:5500,http://localhost:5500,http://127.0.0.1:8000
ALLOWED_HOSTS=endcosmos.com,www.endcosmos.com,localhost,127.0.0.1

# Security
SECRET_KEY=replace_with_a_long_random_secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
TRUST_PROXY_HEADERS=true
FAILED_LOGIN_WINDOW_MINUTES=15
MAX_FAILED_LOGIN_PER_IP=20
MAX_FAILED_LOGIN_PER_IDENTITY=8
REGISTER_WINDOW_MINUTES=60
MAX_REGISTRATIONS_PER_IP=6
